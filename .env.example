# Service
SERVICE_NAME=tq-user-service
PORT=3002
LOG_LEVEL=INFO

# MongoDB
MONGO_URI=mongodb://127.0.0.1:27017/tq_users

# Redis
REDIS_HOST=127.0.0.1
REDIS_PORT=6379

# Cloudinary
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# JWT - must match GATEWAY_JWT_SECRET in production
JWT_SECRET=dev-secret-change-in-production

# Cache
PROFILE_CACHE_TTL=300